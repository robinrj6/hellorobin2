---
import { getSpotifyStats } from "../lib/spotify";

const { stats, error } = await getSpotifyStats();
---

<section class="spotify" aria-label="Spotify listening stats">
  {
    stats ? (
      <>
        <div class="heading-row">
          <div class="profile-row">
            {
              stats.avatarUrl && (
                <img
                  src={stats.avatarUrl}
                  alt={`${stats.profileName} Spotify profile`}
                  width="56"
                  height="56"
                />
              )
            }
            <a href={stats.profileUrl} target="_blank" rel="noopener noreferrer">
              {stats.profileName}'s Spotify
            </a>
          </div>
          <span
            id="spotify-status-pill"
            class={
              stats.nowPlaying
                ? stats.nowPlaying.isPlaying
                  ? "status-pill status-pill--live"
                  : "status-pill status-pill--paused"
                : "status-pill status-pill--idle"
            }
          >
            {stats.nowPlaying ? (stats.nowPlaying.isPlaying ? "Playing" : "Paused") : "Idle"}
          </span>
        </div>
        <article class="card now-playing-card">
          <h3>Now Playing</h3>
          <div id="spotify-now-playing-slot">
            <div
              id="spotify-now-playing-content"
              class:list={["now-playing-content", !stats.nowPlaying && "is-hidden"]}
            >
              <img
                id="spotify-album-art"
                src={stats.nowPlaying?.albumArtUrl ?? ""}
                alt={stats.nowPlaying ? `${stats.nowPlaying.trackName} album art` : ""}
                width="56"
                height="56"
                class:list={[!stats.nowPlaying?.albumArtUrl && "is-hidden"]}
              />
              <div class="now-playing-meta">
                <span class="playing-state">
                  <span
                    id="spotify-playing-dot"
                    class={stats.nowPlaying?.isPlaying ? "dot dot--live" : "dot"}
                  ></span>
                  <span id="spotify-playing-label">
                    {stats.nowPlaying?.isPlaying ? "Playing now" : "Paused"}
                  </span>
                </span>
                <a
                  id="spotify-track-link"
                  href={stats.nowPlaying?.url ?? "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[!stats.nowPlaying?.url && "is-hidden"]}
                >
                  <strong id="spotify-track-name-link">{stats.nowPlaying?.trackName ?? ""}</strong>
                </a>
                <strong
                  id="spotify-track-name-plain"
                  class:list={[Boolean(stats.nowPlaying?.url) && "is-hidden"]}
                  >{stats.nowPlaying?.trackName ?? ""}</strong
                >
                <span id="spotify-track-artists">{stats.nowPlaying?.artists ?? ""}</span>
              </div>
            </div>
            <p id="spotify-now-playing-idle" class:list={["now-playing-idle", stats.nowPlaying && "is-hidden"]}>
              Nothing playing right now.
            </p>
          </div>
        </article>

        <div class="grid">
          <article class="card">
            <h3>{stats.topGenres.length ? "Top Genres" : "Top Artists"}</h3>
            <ul class="genres">
              {(stats.topGenres.length ? stats.topGenres : stats.topArtists).map((genre) => (
                <li>{genre}</li>
              ))}
            </ul>
          </article>

          <article class="card">
            <h3>Top Tracks</h3>
            <ul class="tracks">
              {stats.topTracks.map((track) => (
                <li>
                  {
                    track.url ? (
                      <a href={track.url} target="_blank" rel="noopener noreferrer">
                        <strong>{track.name}</strong>
                        <span>{track.artists}</span>
                      </a>
                    ) : (
                      <>
                        <strong>{track.name}</strong>
                        <span>{track.artists}</span>
                      </>
                    )
                  }
                </li>
              ))}
            </ul>
          </article>
        </div>
      </>
    ) : (
      <p class="fallback">
        Spotify stats are unavailable right now.
        {error ? ` ${error}` : ""}
      </p>
    )
  }
</section>

<script>
  const statusPill = document.getElementById("spotify-status-pill");
  const nowPlayingContent = document.getElementById("spotify-now-playing-content");
  const nowPlayingIdle = document.getElementById("spotify-now-playing-idle");
  const albumArt = document.getElementById("spotify-album-art") as HTMLImageElement | null;
  const playingDot = document.getElementById("spotify-playing-dot");
  const playingLabel = document.getElementById("spotify-playing-label");
  const trackLink = document.getElementById("spotify-track-link") as HTMLAnchorElement | null;
  const trackNameLink = document.getElementById("spotify-track-name-link");
  const trackNamePlain = document.getElementById("spotify-track-name-plain");
  const trackArtists = document.getElementById("spotify-track-artists");

  type NowPlayingPayload = {
    isPlaying: boolean;
    trackName: string;
    artists: string;
    url: string | null;
    albumArtUrl: string | null;
  };

  const renderStatus = (nowPlaying: {
    isPlaying: boolean;
  } | null) => {
    if (!statusPill) return;

    statusPill.className = "status-pill";

    if (!nowPlaying) {
      statusPill.classList.add("status-pill--idle");
      statusPill.textContent = "Idle";
      return;
    }

    if (nowPlaying.isPlaying) {
      statusPill.classList.add("status-pill--live");
      statusPill.textContent = "Playing";
      return;
    }

    statusPill.classList.add("status-pill--paused");
    statusPill.textContent = "Paused";
  };

  const renderNowPlaying = (nowPlaying: NowPlayingPayload | null) => {
    if (!nowPlayingContent || !nowPlayingIdle) return;
    if (!nowPlaying) {
      nowPlayingContent.classList.add("is-hidden");
      nowPlayingIdle.classList.remove("is-hidden");
      return;
    }

    nowPlayingContent.classList.remove("is-hidden");
    nowPlayingIdle.classList.add("is-hidden");

    if (playingDot) {
      playingDot.className = nowPlaying.isPlaying ? "dot dot--live" : "dot";
    }
    if (playingLabel) {
      playingLabel.textContent = nowPlaying.isPlaying ? "Playing now" : "Paused";
    }

    if (albumArt) {
      if (nowPlaying.albumArtUrl) {
        albumArt.src = nowPlaying.albumArtUrl;
        albumArt.alt = `${nowPlaying.trackName} album art`;
        albumArt.classList.remove("is-hidden");
      } else {
        albumArt.classList.add("is-hidden");
      }
    }

    if (trackNameLink) {
      trackNameLink.textContent = nowPlaying.trackName;
    }
    if (trackNamePlain) {
      trackNamePlain.textContent = nowPlaying.trackName;
    }
    if (trackArtists) {
      trackArtists.textContent = nowPlaying.artists;
    }

    if (trackLink && trackNamePlain) {
      if (nowPlaying.url) {
        trackLink.href = nowPlaying.url;
        trackLink.classList.remove("is-hidden");
        trackNamePlain.classList.add("is-hidden");
      } else {
        trackLink.removeAttribute("href");
        trackLink.classList.add("is-hidden");
        trackNamePlain.classList.remove("is-hidden");
      }
    }
  };

  const refreshSpotify = async () => {
    try {
      const response = await fetch("/api/spotify.json", { cache: "no-store" });
      if (!response.ok) return;

      const payload = (await response.json()) as {
        stats?: {
          nowPlaying: {
            isPlaying: boolean;
            trackName: string;
            artists: string;
            url: string | null;
            albumArtUrl: string | null;
          } | null;
        } | null;
      };

      const nowPlaying = payload?.stats?.nowPlaying ?? null;
      renderStatus(nowPlaying);
      renderNowPlaying(nowPlaying);
    } catch {
      // no-op
    }
  };

  window.setInterval(refreshSpotify, 15000);
  refreshSpotify();
</script>

<style>
  .spotify {
    margin-top: 2rem;
    padding: 1.25rem 1.25rem 1.35rem;
    font-family: 'Courier New', Courier, monospace;
    border-radius: 18px;
    background:
      radial-gradient(circle at top right, rgba(29, 185, 84, 0.18), transparent 42%),
      linear-gradient(160deg, rgba(17, 17, 17, 0.92), rgba(9, 9, 9, 0.88));
    border: 1px solid rgba(29, 185, 84, 0.32);
    box-shadow: 0 16px 30px rgb(0 0 0 / 35%), inset 0 1px 0 rgb(255 255 255 / 7%);
    max-width: 760px;
    margin-inline: auto;
  }

  .heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .spotify h2 {
    margin: 0;
    color: #f7f7f7;
    font-size: 1.35rem;
    letter-spacing: 0.02em;
    text-align: left;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    padding: 0.3rem 0.62rem;
  }

  .status-pill--live {
    color: #101910;
    background: #1db954;
    box-shadow: 0 0 18px rgba(29, 185, 84, 0.35);
  }

  .status-pill--idle {
    color: #cbdbd2;
    background: rgba(140, 155, 147, 0.22);
    border: 1px solid rgba(173, 190, 180, 0.35);
  }

  .status-pill--paused {
    color: #ffecc8;
    background: rgba(255, 191, 71, 0.22);
    border: 1px solid rgba(255, 191, 71, 0.45);
  }

  .profile-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .profile-row img {
    border-radius: 999px;
    border: 1px solid rgba(29, 185, 84, 0.58);
    box-shadow: 0 8px 16px rgb(0 0 0 / 35%);
  }

  .profile-row a {
    color: #d8fbe4;
    text-decoration: none;
    font-weight: 600;
  }

  .profile-row a:hover {
    text-decoration: underline;
  }

  .grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: 1fr 1fr;
  }

  .now-playing-card {
    margin-bottom: 0.9rem;
  }

  .now-playing-content {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .now-playing-content img {
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .is-hidden {
    display: none !important;
  }

  .now-playing-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-align: left;
  }

  .playing-state {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #a4cab2;
  }

  .dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: #5f7669;
    display: inline-block;
  }

  .dot--live {
    background: #1db954;
    box-shadow: 0 0 0.4rem rgba(29, 185, 84, 0.85);
  }

  .now-playing-meta a {
    color: inherit;
    text-decoration: none;
  }

  .now-playing-meta a:hover strong {
    color: #1db954;
  }

  .now-playing-meta strong {
    color: #f0fff5;
    font-size: 0.95rem;
  }

  .now-playing-meta span {
    color: #9db6a7;
    font-size: 0.82rem;
  }

  .now-playing-idle {
    margin: 0;
    color: #9db6a7;
    text-align: left;
    font-size: 0.86rem;
  }

  .card {
    background: linear-gradient(165deg, rgba(32, 32, 32, 0.76), rgba(20, 20, 20, 0.72));
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 0.9rem;
  }

  .card h3 {
    margin: 0 0 0.7rem;
    font-size: 1rem;
    color: #c6f5d6;
    text-align: left;
  }

  .genres,
  .tracks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .genres {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .genres li {
    font-size: 0.78rem;
    color: #d7ffe6;
    background: rgba(29, 185, 84, 0.16);
    border: 1px solid rgba(29, 185, 84, 0.45);
    border-radius: 999px;
    padding: 0.32rem 0.65rem;
    text-transform: capitalize;
  }

  .tracks li {
    text-align: left;
  }

  .tracks a {
    color: inherit;
    text-decoration: none;
  }

  .tracks strong {
    display: block;
    color: #f0fff5;
    font-size: 0.9rem;
    margin-bottom: 0.1rem;
  }

  .tracks span {
    color: #9db6a7;
    font-size: 0.8rem;
  }

  .tracks li:hover strong {
    color: #1db954;
  }

  .fallback {
    margin: 0;
    color: #adb6b0;
    text-align: left;
    line-height: 1.5;
  }

  @media (max-width: 700px) {
    .spotify {
      padding: 1rem;
      border-radius: 14px;
      margin-top: 1.25rem;
    }

    .heading-row {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .profile-row {
      flex-wrap: wrap;
    }

    .profile-row img {
      width: 42px;
      height: 42px;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .now-playing-content img {
      width: 48px;
      height: 48px;
    }

    .now-playing-meta strong {
      font-size: 0.88rem;
    }

    .card h3 {
      font-size: 0.92rem;
    }

    .genres li {
      font-size: 0.72rem;
      padding: 0.25rem 0.5rem;
    }

    .tracks strong {
      font-size: 0.84rem;
    }

    .tracks span {
      font-size: 0.75rem;
    }
  }
</style>
