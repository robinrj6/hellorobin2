---
import skillsData from "../../public/data/skills.json";
---

<div class="skills">
  <h1>Skills That Keep the Lights On ⚡️</h1>
  <img
    src="/images/lightning.svg"
    alt="Know Me Icon"
    width="200"
    height="200"
    class="backgroundimg"
  />
  <ul class="skills-list">
    {
      skillsData.map((skill) => (
        <li class="skill-item">
          <img src={skill.icon} alt={skill.name} />
          <span>{skill.name}</span>
        </li>
      ))
    }
  </ul>
</div>

<style>
  @property --border-angle {
    syntax: "<angle>";
    inherits: false;
    initial-value: 0deg;
  }

  @font-face {
    font-family: "Hurmit";
    src: url("/src/assets/fonts/HurmitNerdFont-Regular.otf") format("opentype");
  }
  h1 {
    text-align: left;
    font-family: "Hurmit", sans-serif;
    color: rgba(182, 182, 182, 0.718);
    margin-bottom: 1rem;
  }

  .skills {
    display: flex;
    flex-direction: column;
    min-height: max-content;
    position: relative;
  }

  .skills-list {
    --border-angle: 0deg;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    padding: 2rem;
    justify-content: center;
    row-gap: 1rem;
    column-gap: 1rem;
    width: 65vw;
    max-height: 80vh;
    border-radius: 12px;
    position: relative;
    border: 3px solid transparent;
    cursor: default;
    background:
      linear-gradient(rgba(42, 33, 26, 1), rgba(42, 33, 26, 1))
        padding-box,
      conic-gradient(
        from var(--border-angle),
        rgba(255, 255, 255, 0.1) 0deg,
        rgba(255, 255, 255, 0.1) 320deg,
        rgba(182, 82, 255, 0.95) 338deg,
        rgba(255, 255, 255, 1) 349deg,
        rgba(182, 82, 255, 0.95) 356deg,
        rgba(255, 255, 255, 0.1) 360deg
      ) border-box;
    box-shadow: 0 0 20px rgba(182, 82, 255, 0.12);
    animation: border-flow 4s linear infinite;
  }

  @keyframes border-flow {
    to {
      --border-angle: 360deg;
    }
  }
  .backgroundimg {
    position: absolute;
    top: 0;
    right: 50%;
    width: 150px;
    height: 150px;
    opacity: 0.5;
    filter: brightness(0) saturate(100%) invert(60%) hue-rotate(100deg)
      contrast(45%);
  }
  .skill-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    width: fit-content;
    height: max-content;
    color: #c0c0c0;
    font-family: "Hurmit", sans-serif;
    background-color: rgba(83, 82, 82, 0.667);
    border-radius: 10px;
    box-shadow:
      0 4px 6px rgb(0 0 0 / 20%),
      0 0 10px rgb(0 0 0 / 10%);
    border: 1px solid #ededed5f;
    padding: 0.5rem 1rem;
    position: relative;
    overflow: hidden;
  }
  .skill-item:hover {
    background-color: rgba(83, 82, 82, 0.8);
    box-shadow:
      0 4px 6px rgb(0 0 0 / 30%),
      0 0 15px rgb(0 0 0 / 20%);
    border: 1px solid #ededed9f;
    transform: translateY(-2px);
    transition: all 0.3s ease;
  }

  .skill-item::after {
    content: "";
    position: absolute;
    top: 0;
    left: -140%;
    width: 45%;
    height: 100%;
    background: linear-gradient(
      110deg,
      transparent 0%,
      rgba(255, 255, 255, 0.75) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    opacity: 0;
    pointer-events: none;
  }

  .skill-item:hover::after {
    opacity: 1;
    animation: silver-flash 0.7s ease-out 1;
  }

  @keyframes silver-flash {
    0% {
      left: -140%;
    }
    100% {
      left: 140%;
    }
  }

  .skill-item span {
    text-align: center;
    font-size: 0.875rem;
  }
  .skill-item img {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }
  @media screen and (max-width: 700px) {
    .skills {
      margin-top: 5rem;
      justify-content: center;
        align-items: center;
    }
    .skills-list {
      width: 75vw;
      padding: 1rem;
      overflow-y: scroll;
      overflow-x: hidden ;
    }
  }
</style>
