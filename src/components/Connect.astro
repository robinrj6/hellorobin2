---
import SpotifyStats from "./SpotifyStats.astro";
---

<div class="connect">
  <h1>Connect with Me</h1>
  <p>
    If you'd like to get in touch, feel free to reach out via email or connect
    on LinkedIn!
  </p>
  <ul>
    <li>
      <a href="mailto:robinrjr10germany@gmail.com">
        <img src="/images/mail-heart.svg" alt="" /></a>
    </li>
    <li>
      <a
        href="https://www.linkedin.com/in/robin-jose-raju/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img src="/images/brand-linkedin.svg" alt="" /></a>
    </li>
    <li>
      <a
        href="https://www.github.com/robinrj6"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img src="/images/brand-github.svg" alt="" /></a>
    </li>
  </ul>

  <SpotifyStats />
</div>

<style>
  @font-face {
    font-family: "Hurmit";
    src: url("/src/assets/fonts/HurmitNerdFont-Regular.otf") format("opentype");
  }

  .connect {
    text-align: center;
    font-family: "Neighbor", sans-serif;
    padding: 1.5rem 1rem;
    max-width: 860px;
    margin-inline: auto;
    margin-top: 1rem;
    box-sizing: border-box;
  }

  h1 {
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    margin-bottom: 0.75rem;
    color: #b6b6b6;
  }

  p {
    font-size: clamp(0.95rem, 2.5vw, 1.2rem);
    font-family: Hurmit, sans-serif;
    margin-bottom: 1.75rem;
    color: #707070fc;
    line-height: 1.6;
    padding-inline: 0.5rem;
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: clamp(1rem, 5vw, 2rem);
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  li img {
    width: clamp(32px, 8vw, 40px);
    height: clamp(32px, 8vw, 40px);
    transition: transform 0.2s;
    filter: brightness(0) saturate(100%) invert(60%) hue-rotate(100deg)
      contrast(45%);
  }

  li img:hover {
    transform: scale(1.1);
  }
</style>
